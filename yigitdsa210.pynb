   "source": [
    "# EDA Summary\n",
    "# Goals and assists are positively associated with market value.\n",
    "# Goals appear to have a stronger effect than assists.\n",
    "# Age shows a non-linear relationship with market value.\n",
    "# Overall, attacking performance is an important determinant of market value, \n",
    "# although it is not the only influencing factor."
   ]
  }
