  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "d502406e-44db-4fae-88e6-646c8f0f32b4",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = df.drop(columns=[\"Gls.1\", \"Ast.1\"], errors=\"ignore\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "35ef0946-3493-405b-b499-01795f8568f1",
   "metadata": {},
   "outputs": [],
   "source": [
    "def convert_market_value(x):\n",
    "    if pd.isna(x):\n",
    "        return None\n",
    "    \n",
    "    x = str(x).strip()\n",
    "    x = x.replace(\"€\", \"\")\n",
    "    x = x.lower()\n",
    "    \n",
    "    if x.endswith(\"m\"):\n",
    "        return float(x[:-1]) * 1000000\n",
    "    elif x.endswith(\"k\"):\n",
    "        return float(x[:-1]) * 1000\n",
    "    else:\n",
    "        return float(x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "e99831db-7643-4439-894c-f2f8b8c9f21c",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[\"Market Value Numeric\"] = df[\"Market Value\"].apply(convert_market_value)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "701788a0-8ceb-40ee-b81c-ecb47314c4fe",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[\"Age\"] = pd.to_numeric(df[\"Age\"], errors=\"coerce\")\n",
    "df[\"MP\"] = pd.to_numeric(df[\"MP\"], errors=\"coerce\")\n",
    "df[\"Starts\"] = pd.to_numeric(df[\"Starts\"], errors=\"coerce\")\n",
    "df[\"Min\"] = pd.to_numeric(df[\"Min\"], errors=\"coerce\")\n",
    "df[\"Gls\"] = pd.to_numeric(df[\"Gls\"], errors=\"coerce\")\n",
    "df[\"Ast\"] = pd.to_numeric(df[\"Ast\"], errors=\"coerce\")\n",
    "df[\"G+A\"] = pd.to_numeric(df[\"G+A\"], errors=\"coerce\")"
   ]
  },
