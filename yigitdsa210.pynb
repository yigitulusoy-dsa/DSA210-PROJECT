   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.stats import pearsonr\n",
    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "df = pd.read_excel(\"yigitdsa210data.xlsx\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "090cc6f2-765c-4dc0-80ff-619f21eb89b4",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "Index(['Player', 'Nation', 'Pos', 'Squad', 'Age', 'Born', 'MP', 'Starts',\n",
       "       'Min', 'Gls', 'Ast', 'G+A', 'Market Value'],\n",
       "      dtype='object')"
      ]
     },
     "execution_count": 15,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "df = df.drop(columns=[\"Gls.1\", \"Ast.1\"], errors=\"ignore\")\n",
    "df.columns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "100a5f22-543f-42ff-a331-ad4f3a7bf247",
   "metadata": {},
   "outputs": [],
   "source": [
    "def convert_market_value(x):\n",
    "    if pd.isna(x):\n",
    "        return None\n",
    "    \n",
    "    x = str(x).strip()\n",
    "    x = x.replace(\"€\", \"\")\n",
    "    x = x.lower()\n",
    "    \n",
    "    if x.endswith(\"m\"):\n",
    "        return float(x[:-1]) * 1000000\n",
    "    elif x.endswith(\"k\"):\n",
    "        return float(x[:-1]) * 1000\n",
    "    else:\n",
    "        return float(x)\n",
    "\n",
    "df[\"Market Value Numeric\"] = df[\"Market Value\"].apply(convert_market_value)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "5f6f97ad-8cf5-46a7-a345-b78f4092334c",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[\"Min\"] = df[\"Min\"].astype(str).str.replace(\",\", \"\", regex=False)\n",
    "df[\"Min\"] = pd.to_numeric(df[\"Min\"], errors=\"coerce\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "01f44839-0762-4079-9bef-0b5ef5f33cf8",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[\"Age\"] = pd.to_numeric(df[\"Age\"], errors=\"coerce\")\n",
    "df[\"MP\"] = pd.to_numeric(df[\"MP\"], errors=\"coerce\")\n",
    "df[\"Starts\"] = pd.to_numeric(df[\"Starts\"], errors=\"coerce\")\n",
    "df[\"Gls\"] = pd.to_numeric(df[\"Gls\"], errors=\"coerce\")\n",
    "df[\"Ast\"] = pd.to_numeric(df[\"Ast\"], errors=\"coerce\")\n",
    "df[\"G+A\"] = pd.to_numeric(df[\"G+A\"], errors=\"coerce\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "9d557598-467e-4a02-b1cc-e2692463292f",
   "metadata": {},
   "outputs": [
